rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the authenticated user can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Activities: user can only access their own activities
    match /activities/{activityId} {
      allow read, write: if request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/activities/$(activityId)).data.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Carbon history: user can only access their own history
    match /carbon_history/{docId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Challenges: read for all authenticated, write only for own
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Leaderboard: all authenticated users can read
    match /leaderboard/{entryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // Reports: user can only access their own reports
    match /reports/{reportId} {
      allow read, write: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
    }

    // AI reports: user can only access their own reports
    match /ai_reports/{reportId} {
      allow read: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
