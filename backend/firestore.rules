rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    function isValidNumber(field) {
      return field is number || field is int;
    }

    // ── Users ─────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys().hasAll(['email', 'name'])
        && isValidString(request.resource.data.email, 120)
        && isValidString(request.resource.data.name, 100);
      allow update: if isOwner(userId)
        && (!request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['uid', 'createdAt']));
      allow delete: if false;
    }

    // ── Activities ────────────────────────────────────────────────

    match /activities/{activityId} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'transport', 'distance', 'food_type'])
        && isValidString(request.resource.data.transport, 50)
        && isValidNumber(request.resource.data.distance)
        && request.resource.data.distance >= 0;
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── Carbon history ────────────────────────────────────────────

    match /carbon_history/{docId} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'date', 'carbon_score'])
        && isValidNumber(request.resource.data.carbon_score);
      allow update: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── Challenges ────────────────────────────────────────────────

    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── Leaderboard (read-only for users, backend writes only) ───

    match /leaderboard/{entryId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // ── Reports ───────────────────────────────────────────────────

    match /reports/{reportId} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── AI reports ────────────────────────────────────────────────

    match /ai_reports/{reportId} {
      allow read: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated()
        && resource.data.uid == request.auth.uid;
    }

    // ── Conversations ─────────────────────────────────────────────

    match /conversations/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Token blacklist (backend-only) ────────────────────────────

    match /token_blacklist/{tokenId} {
      allow read, write: if false;
    }

    // ── Deny everything else ──────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
