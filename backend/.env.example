# ═══════════════════════════════════════════════════════════════════
# EcoMentor AI — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── REQUIRED ──────────────────────────────────────────────────────

# Flask secret key — minimum 32 random characters
SECRET_KEY=change-me-to-a-random-32-char-string

# Gemini API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key

# Google Cloud Project ID
GCP_PROJECT_ID=ecomentor-ai

# ── FIREBASE / FIRESTORE ─────────────────────────────────────────

# Firebase API key (for client SDK)
FIREBASE_API_KEY=

# Service account credentials (for server-side Firestore access)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firestore emulator (development only — leave blank in production)
FIRESTORE_EMULATOR_HOST=

# ── APPLICATION ───────────────────────────────────────────────────

# Environment: development | testing | production
APP_ENV=development

# JWT token expiry in hours
JWT_EXPIRY_HOURS=24

# CORS allowed origins (comma-separated in production)
CORS_ORIGINS=http://localhost:5000,http://localhost:8080

# ── RATE LIMITING ─────────────────────────────────────────────────

# Enable rate limiting (True/False)
RATE_LIMIT_ENABLED=True

# Format: "capacity;window_seconds"
RATE_LIMIT_DEFAULT=100;3600
RATE_LIMIT_STRICT=10;60

# Global rate limit
RATE_LIMIT_GLOBAL_CAPACITY=1000
RATE_LIMIT_GLOBAL_REFILL=10

# ── AI PIPELINE ───────────────────────────────────────────────────

# Gemini response cache TTL in seconds (default: 1 hour)
GEMINI_CACHE_TTL=3600

# Internal API key for Cloud Scheduler endpoints
INTERNAL_API_KEY=
