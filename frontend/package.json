{
  "name": "ecomentor-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deploy:gen-config": "node scripts/generate-firebase-json.js",
    "deploy": "npm run build && node scripts/generate-firebase-json.js && cd .. && npx firebase-tools deploy --only hosting"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "vite": "^6.4.3",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "firebase": "^12.15.0"
  }
}
